# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (message @userinfobot to get it)
TELEGRAM_USER_ID=

# Optional: default project path for Claude Code
# DEFAULT_PROJECT_PATH=/home/user/myproject

# Optional: path to claude CLI (defaults to "claude" from PATH)
# CLAUDE_CLI_PATH=claude

# Optional: whisper.cpp model name for voice transcription (default: base)
# Requires whisper.cpp and ffmpeg installed. Voice support is disabled if not found.
# WHISPER_MODEL=base

# Optional: full path to whisper model .bin file (overrides WHISPER_MODEL)
# WHISPER_MODEL_PATH=
